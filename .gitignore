# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Root .gitignore — covers the whole repo (skyjet-recovery/, docs/, research/).
# The Next.js app also has its own skyjet-recovery/.gitignore.

# dependencies (any depth — catches skyjet-recovery/node_modules)
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js / build output
.next/
out/
build/
dist/

# testing / coverage
coverage/

# env files (opt-in for committing via .env.example)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# OS junk
.DS_Store
Thumbs.db

# editor / IDE
.vscode/
.idea/
*.swp

# certs / keys
*.pem

# scratch / temp
scratchpad/
tmp/
*.tmp
