# ── Optional: RAG chatbot (Gemini embeddings + Pinecone) ─────────────────────
# The app runs fully WITHOUT these — the Disruption Assistant then uses the
# built-in deterministic keyword retrieval. Set all of them to light up the
# semantic path. Copy this file to .env.local (never commit real keys).

# Google AI Studio key — used for gemini-embedding-001 + gemini-2.5-flash
GEMINI_API_KEY=

# Pinecone (serverless) — index is created automatically on first reindex
PINECONE_API_KEY=
PINECONE_INDEX=skyjet-policies
# Optional overrides:
# PINECONE_INDEX_HOST=            # data-plane host; skips the control-plane lookup
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1
# GEMINI_EMBED_MODEL=gemini-embedding-001
# GEMINI_CHAT_MODEL=gemini-2.5-flash

# Guards the ops/admin panel (/admin, POST /api/admin/flight) and the RAG
# reindex endpoint. In development the panel falls back to a well-known token
# ("skyjet-ops-2026") so it works out-of-the-box; in production it is DISABLED
# until you set this. Set it in your deployment (e.g. Vercel) to enable /admin.
ADMIN_TOKEN=
